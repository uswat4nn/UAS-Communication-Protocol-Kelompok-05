    {
      "name": "P10 n8n Webhook Trigger",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"n8n response is JSON\", function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "",
              "pm.test(\"Response has workflowResult\", function () {",
              "    pm.expect(jsonData).to.have.property(\"workflowResult\");",
              "});",
              "",
              "pm.test(\"Response has workflowBranch\", function () {",
              "    pm.expect(jsonData).to.have.property(\"workflowBranch\");",
              "});",
              "",
              "pm.test(\"Response has executedNode\", function () {",
              "    pm.expect(jsonData).to.have.property(\"executedNode\");",
              "});",
              "",
              "pm.test(\"Response has backendStatusCode\", function () {",
              "    pm.expect(jsonData).to.have.property(\"backendStatusCode\");",
              "});",
              "",
              "pm.test(\"Postman HTTP status mirrors backendStatusCode\", function () {",
              "    pm.expect(pm.response.code).to.eql(jsonData.backendStatusCode);",
              "});",
              "",
              "pm.test(\"HTTP status is 200 or 429 for this demo\", function () {",
              "    pm.expect([200, 429]).to.include(pm.response.code);",
              "});",
              "",
              "if (pm.response.code === 200) {",
              "    pm.test(\"Workflow hit success branch\", function () {",
              "        pm.expect(jsonData.workflowBranch).to.eql(\"TRUE_BRANCH_SUCCESS\");",
              "        pm.expect(jsonData.executedNode).to.eql(\"Build Success Response\");",
              "        pm.expect(jsonData.responseCodeSent).to.eql(200);",
              "    });",
              "}",
              "",
              "if (pm.response.code === 429) {",
              "    pm.test(\"Workflow hit error branch and returns real HTTP 429\", function () {",
              "        pm.expect(jsonData.workflowBranch).to.eql(\"FALSE_BRANCH_ERROR\");",
              "        pm.expect(jsonData.executedNode).to.eql(\"Build Error Response\");",
              "        pm.expect(jsonData.responseCodeSent).to.eql(429);",
              "    });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
